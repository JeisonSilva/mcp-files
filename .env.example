# ──────────────────────────────────────────────────────────────────────────────
# LangGraph MCP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de executar.
# NUNCA versione o arquivo .env real no git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── OpenRouter ───────────────────────────────────────────────────────────────
# Chave de API do OpenRouter (obtenha em https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Modelo padrão a usar (ex.: openai/gpt-4o, anthropic/claude-3-5-sonnet, etc.)
# Consulte modelos disponíveis em https://openrouter.ai/models
OPENROUTER_MODELO=openai/gpt-4o-mini

# URL base da API OpenRouter (compatível com OpenAI)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Temperatura do modelo (0.0 = determinístico, 1.0 = criativo)
OPENROUTER_TEMPERATURA=0.7

# Número máximo de tokens na resposta
OPENROUTER_MAX_TOKENS=4096

# ─── MCP Files ────────────────────────────────────────────────────────────────
# Caminho raiz que o servidor MCP files pode acessar
MCP_FILES_RAIZ=/

# Comando para iniciar o servidor MCP files (ex.: npx @modelcontextprotocol/server-filesystem)
MCP_FILES_COMANDO=npx

# Argumentos adicionais para o comando do servidor MCP files
MCP_FILES_ARGS=@modelcontextprotocol/server-filesystem /

# ─── Servidor MCP (este projeto) ─────────────────────────────────────────────
# Nome do servidor exibido para clientes MCP (Cursor, Copilot)
MCP_SERVIDOR_NOME=langgraph-mcp

# Versão do servidor
MCP_SERVIDOR_VERSAO=1.0.0

# ─── LangSmith (opcional — rastreamento de execuções) ────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=langgraph-mcp
